# Required — get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Required — get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Auto-detected from server IP if empty
# BASE_URL=https://your-domain.com

# AES-256 encryption key for P12 files: openssl rand -hex 32
# MASTER_KEY=

# Password to protect the web dashboard at /dashboard
# ADMIN_PASSWORD=

# WORKER_CONCURRENCY=2
# RETENTION_DAYS_DEFAULT=7
# ZSIGN_MOCK=false
# DEBUG=false
