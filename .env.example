# === Required ===
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
BASE_URL=https://your-domain.com

# === Telegram Mode ===
# webhook or polling (default: polling)
TELEGRAM_MODE=polling
# Required if TELEGRAM_MODE=webhook
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Storage ===
STORAGE_PATH=/storage

# === Security ===
# Generate with: openssl rand -hex 32
# If set, P12 files and passwords are encrypted at rest with AES-256-GCM.
# If unset, P12 stored chmod 600 and password must be provided per-job.
# MASTER_KEY=

# === Limits ===
MAX_IPA_MB=500
MAX_P12_MB=20
MAX_PROV_KB=512
MAX_CERTSETS_PER_USER=3

# === Worker ===
WORKER_CONCURRENCY=2
USER_CONCURRENCY=1
JOB_TIMEOUT_SIGNING_SECONDS=900
VISIBILITY_TIMEOUT_SECONDS=600

# === Retention ===
RETENTION_DAYS_DEFAULT=7
